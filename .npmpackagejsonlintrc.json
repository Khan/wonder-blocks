{
    "rules": {
        "require-main": "error",
        "require-module": "error",
        "require-name": "error",
        "require-types": "error",
        "require-version": "error",
        "valid-values-publishConfig": [
            "error",
            [
                {
                    "access": "public"
                },
                {
                    "access": "restricted"
                }
            ]
        ]
    },
    "overrides": [
        {
            "patterns": ["packages/eslint-plugin-wonder-blocks/demo/package.json"],
            "rules": {
                "require-main": "off",
                "require-module": "off",
                "require-types": "off"
            }
        }
    ]
}