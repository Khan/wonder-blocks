{
    "editor.renderWhitespace": "boundary",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "eslint.enable": true,
    "files.trimTrailingWhitespace": true,
    "js/ts.validate.enabled": true,
    "js/ts.format.enabled": false,
    "js/ts.tsdk.path": "node_modules/typescript/lib",
    "js/ts.tsserver.experimental.enableProjectDiagnostics": true,
    "files.associations": {
        "*.flow": "plaintext",
    },
    "flow.enabled": false,

    // Inlay Hints
    "editor.inlayHints.enabled": "offUnlessPressed",
    "js/ts.inlayHints.enumMemberValues.enabled": true,
    "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
    "js/ts.inlayHints.parameterNames.enabled": "all",
    "js/ts.inlayHints.parameterTypes.enabled": true,
    "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
    "js/ts.inlayHints.variableTypes.enabled": true,

    "jest.jestCommandLine": "pnpm jest",
    // CSS Variable Autocomplete (`vunguyentuan.vscode-css-variables`). Points
    // at the merged token CSS so authors get autocomplete + hover docs for
    // every `--wb-*` custom property defined by
    // `@khanacademy/wonder-blocks-tokens`. The file is generated by `pnpm
    // build:css` (run automatically as part of `pnpm build` / `pnpm lint:css`);
    // on a fresh checkout, run `pnpm build` once before expecting the popup.
    "cssVariables.lookupFiles": [
        "packages/wonder-blocks-tokens/dist/css/vars.css",
    ],
}
